# ── Supabase (required) ──────────────────────────────────────────────────────
# Project URL + publishable (anon) key from Supabase Dashboard → Settings → API.
PUBLIC_SUPABASE_URL=<your_supabase_project_url>
PUBLIC_SUPABASE_ANON_KEY=<your_supabase_anon_key>
# Service-role key — server-only admin operations. NEVER expose to the client.
PRIVATE_SUPABASE_SERVICE_ROLE_KEY=<your_supabase_service_role_key>

# ── Geoscape / PSMA (required for address validation + GNAF tile proxy) ─────
PUBLIC_GEOSCAPE_ADDRESS_API_KEY=<geoscape_address_api_key>
PUBLIC_GEOSCAPE_GNAF_TILES_API_KEY=<geoscape_gnaf_tiles_api_key>

# ── Site configuration ───────────────────────────────────────────────────────
PUBLIC_CONTACT_EMAIL=<contact_email_shown_on_public_pages>
PUBLIC_PRODUCTION_URL=<https://your-production-domain>

# ── Vercel integrations ──────────────────────────────────────────────────────
# Bearer token the weekly /api/cron endpoint requires.
CRON_SECRET=<random_secret_for_cron_endpoint>
# Vercel Edge Config connection string (feature flags/config).
EDGE_CONFIG=<vercel_edge_config_connection_string>

# ── Tooling only (not consumed by the app) ───────────────────────────────────
# Used by .mcp.json / supabase CLI helpers; see docs/database.md.
# SUPABASE_DEV_PROJECT_REF=…        SUPABASE_DEV_ACCESS_TOKEN=…
# SUPABASE_NEWPROD_PROJECT_REF=…    SUPABASE_NEWPROD_ACCESS_TOKEN=…
# SUPABASE_PROD_PROJECT_REF=…       SUPABASE_PROD_ACCESS_TOKEN=…
