{
  "servers": {
    "supabase-dev": {
      "type": "http",
      "url": "https://mcp.supabase.com/mcp?project_ref=${env:SUPABASE_DEV_PROJECT_REF}",
      "headers": {
        "Authorization": "Bearer ${env:SUPABASE_DEV_ACCESS_TOKEN}"
      }
    },
    "supabase-prod": {
      "type": "http",
      "url": "https://mcp.supabase.com/mcp?project_ref=${env:SUPABASE_PROD_PROJECT_REF}",
      "headers": {
        "Authorization": "Bearer ${env:SUPABASE_PROD_ACCESS_TOKEN}"
      }
    },
    "supabase-newprod": {
      "type": "http",
      "url": "https://mcp.supabase.com/mcp?project_ref=${env:SUPABASE_NEWPROD_PROJECT_REF}",
      "headers": {
        "Authorization": "Bearer ${env:SUPABASE_NEWPROD_ACCESS_TOKEN}"
      }
    },
    "svelte": {
      "command": "npx",
      "args": [
        "-y",
        "@sveltejs/mcp"
      ]
    },
    "core-knowledge": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-filesystem",
        "/home/akeown/projects/ai/ai-dev-system/core"
      ]
    },
    "domain-knowledge": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-filesystem",
        "/home/akeown/projects/ai/ai-dev-system/domains/community-environmental-management"
      ]
    },
    "project-design": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-filesystem",
        "/home/akeown/projects/ai/ai-dev-system/projects/soc-dev"
      ]
    },
    "github": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-github"
      ],
      "env": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "${env:GITHUB_BCYCADATA_PERSONAL_ACCESS_TOKEN}"
      }
    },
    "git": {
      "command": "/home/akeown/.local/bin/uvx",
      "args": [
        "mcp-server-git",
        "--repository",
        "/home/akeown/projects/javascript/bcycadata_git/soc-dev"
      ]
    },
    "fetch": {
      "command": "/home/akeown/.local/bin/uvx",
      "args": [
        "mcp-server-fetch"
      ]
    }
  }
}