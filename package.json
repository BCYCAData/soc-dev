{
	"name": "soc-dev",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"engines": {
		"node": ">=22"
	},
	"scripts": {
		"prepare": "git config core.hooksPath .githooks || true",
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"format": "prettier --write .",
		"lint": "npm run lint:styles && prettier --check . && eslint .",
		"lint:styles": "sh scripts/check-styles.sh",
		"update-db-types": "SUPABASE_ACCESS_TOKEN=\"$SUPABASE_NEWPROD_ACCESS_TOKEN\" npx --yes supabase gen types typescript --project-id \"rcnccgyvdgmcnomwcaja\" > db.types.tmp && grep -q 'export type Json' db.types.tmp && mv db.types.tmp src/lib/db.types.ts && prettier --write src/lib/db.types.ts || (rm -f db.types.tmp && echo 'gen types failed - src/lib/db.types.ts left unchanged' && exit 1)",
		"vercel-build": "ls -la src/lib/server/pdf/fonts && vite build",
		"docs:screenshots": "node scripts/docs-screenshots.ts"
	},
	"devDependencies": {
		"@eslint/compat": "^1.2.5",
		"@eslint/js": "^9.18.0",
		"@fontsource/inter": "^5.2.5",
		"@fontsource/open-sans": "^5.2.5",
		"@fontsource/poppins": "^5.2.6",
		"@fontsource/raleway": "^5.2.6",
		"@mapbox/vector-tile": "^2.0.3",
		"@skeletonlabs/skeleton": "^3.1.3",
		"@skeletonlabs/skeleton-svelte": "^1.2.3",
		"@supabase/ssr": "^0.6.1",
		"@supabase/supabase-js": "^2.75.1",
		"@sveltejs/adapter-vercel": "^5.6.3",
		"@sveltejs/kit": "^2.16.0",
		"@sveltejs/vite-plugin-svelte": "^5.0.3",
		"@tailwindcss/vite": "^4.1.8",
		"@types/blob-stream": "^0.1.33",
		"@types/esri-leaflet": "^3.0.3",
		"@types/jsdom": "^21.1.7",
		"@types/leaflet": "^1.9.18",
		"@types/leaflet-draw": "^1.0.12",
		"@types/leaflet-editable": "^1.2.6",
		"@types/leaflet.markercluster": "^1.5.6",
		"@types/pdfmake": "^0.2.11",
		"@types/tabulator-tables": "^6.2.6",
		"@vercel/edge-config": "^1.4.0",
		"autoprefixer": "^10.4.21",
		"blob-stream": "^0.1.3",
		"eslint": "^9.18.0",
		"eslint-config-prettier": "^10.0.1",
		"eslint-plugin-svelte": "^3.0.0",
		"esri-leaflet": "^3.0.16",
		"globals": "^16.0.0",
		"leaflet": "^1.9.4",
		"leaflet-draw": "^1.0.4",
		"leaflet-editable": "^1.3.1",
		"lucide-svelte": "^0.511.0",
		"pbf": "^4.0.1",
		"pdfmake": "^0.2.20",
		"playwright": "^1.61.1",
		"prettier": "3.6.2",
		"prettier-plugin-svelte": "^3.3.3",
		"prettier-plugin-tailwindcss": "^0.6.12",
		"sharp": "^0.35.3",
		"svelte": "^5.33.11",
		"svelte-check": "^4.2.1",
		"tabulator-tables": "^6.3.1",
		"tailwindcss": "^4.1.8",
		"typescript": "^5.8.3",
		"typescript-eslint": "^8.33.0",
		"vite": "^6.3.5"
	},
	"dependencies": {
		"@vercel/analytics": "^2.0.1",
		"leaflet-geometryutil": "^0.10.3",
		"leaflet.markercluster": "^1.5.3"
	}
}
